# LLM provider — choose one, set LLM_PROVIDER accordingly
LLM_PROVIDER=gemini          # gemini | groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# No search API used — the agent researches from seed URLs in each client's config
# (see sample_configs/) plus a couple of predictable review-site URL guesses
# (app/tools/search.py). No API key needed.

# Hard cost/run-time safety caps
MAX_TOOL_CALLS_PER_RUN=25
MAX_TOKENS_PER_RUN=200000
