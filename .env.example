# LLM provider — choose one, set LLM_PROVIDER accordingly
LLM_PROVIDER=gemini          # gemini | groq

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Search — Brave Search API (free tier, no card required)
BRAVE_API_KEY=

# Hard cost/run-time safety caps
MAX_TOOL_CALLS_PER_RUN=25
MAX_TOKENS_PER_RUN=200000
